{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MarathiLipi",
  "scopeName": "source.marathilipi",
  "fileTypes": [".ml"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-literals" },
    { "include": "#multiword-keywords" },
    { "include": "#console-keywords" },
    { "include": "#variable-keywords" },
    { "include": "#control-keywords" },
    { "include": "#loop-keywords" },
    { "include": "#function-keywords" },
    { "include": "#class-keywords" },
    { "include": "#module-keywords" },
    { "include": "#error-keywords" },
    { "include": "#ts-type-keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.block.marathilipi",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.marathilipi" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.marathilipi" }
          }
        },
        {
          "name": "comment.line.number-sign.marathilipi",
          "begin": "#",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.marathilipi" }
          }
        },
        {
          "name": "comment.line.double-slash.marathilipi",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.marathilipi" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.marathilipi",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.marathilipi" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.marathilipi" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.marathilipi",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.marathilipi",
          "begin": "'",
          "end": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.marathilipi" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.marathilipi" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.marathilipi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "template-literals": {
      "name": "string.template.marathilipi",
      "begin": "`",
      "end": "`",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.template.begin.marathilipi" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.template.end.marathilipi" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.marathilipi",
          "match": "\\\\."
        },
        {
          "name": "meta.template.expression.marathilipi",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.marathilipi" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.marathilipi" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },

    "multiword-keywords": {
      "comment": "Multi-word phrases matched FIRST so component words are not matched individually",
      "patterns": [
        {
          "name": "keyword.declaration.variable.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])स्थिर नाव(?![\\w\\u0900-\\u097F])"
        },
        {
          "name": "keyword.declaration.variable.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])जुने नाव(?![\\w\\u0900-\\u097F])"
        },
        {
          "name": "keyword.other.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])मूळ द्या(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "console-keywords": {
      "comment": "Console / output functions",
      "patterns": [
        {
          "name": "support.function.console.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(दाखवा|सांगा|सांग|छापा|चूक|सूचना|माहिती)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "variable-keywords": {
      "comment": "Variable declaration keywords",
      "patterns": [
        {
          "name": "keyword.declaration.variable.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(नाव|कायम|चल|स्थिर)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "control-keywords": {
      "comment": "Control-flow keywords",
      "patterns": [
        {
          "name": "keyword.control.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(जर|नाहीतर|निवडा|प्रकरण|मूळ|थांब|पुढे)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "loop-keywords": {
      "comment": "Loop keywords",
      "patterns": [
        {
          "name": "keyword.control.loop.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(पुन्हा|जोपर्यंत|करा)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "function-keywords": {
      "comment": "Function-related keywords",
      "patterns": [
        {
          "name": "keyword.declaration.function.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(काम|कार्य)(?![\\w\\u0900-\\u097F])"
        },
        {
          "name": "keyword.control.flow.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(परत|वेढा)(?![\\w\\u0900-\\u097F])"
        },
        {
          "name": "keyword.control.async.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(समकाल|असिन्क्रॉन|प्रतीक्षा)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "class-keywords": {
      "comment": "Class and object keywords",
      "patterns": [
        {
          "name": "keyword.declaration.class.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(प्रकार|वर्ग)(?![\\w\\u0900-\\u097F])"
        },
        {
          "name": "keyword.other.class.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(वाढवा|नवीन|हा|पालक|निर्माता)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "module-keywords": {
      "comment": "Import/export keywords",
      "patterns": [
        {
          "name": "keyword.control.import-export.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(आणा|पासून|द्या)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "error-keywords": {
      "comment": "Error handling keywords",
      "patterns": [
        {
          "name": "keyword.control.exception.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(प्रयत्न|पकडा|शेवटी|फेका)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "ts-type-keywords": {
      "comment": "TypeScript-specific type-level keywords",
      "patterns": [
        {
          "name": "keyword.other.type.marathilipi",
          "match": "(?<![\\w\\u0900-\\u097F])(प्रकारघोषणा|अंतरफलक|नामविश्व|जाहीर|अमूर्त|सार्वजनिक|खाजगी|संरक्षित|स्थिरसदस्य|फक्तवाचा|की|अनुमान|संतोष|हटवा|मध्ये|उदाहरण)(?![\\w\\u0900-\\u097F])"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.marathilipi",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.marathilipi",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.marathilipi",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.marathilipi",
          "match": "\\b0[oO][0-7]+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.marathilipi",
          "match": "(?<!=)(=)(?!=)"
        },
        {
          "name": "keyword.operator.comparison.marathilipi",
          "match": "(===|!==|==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.marathilipi",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.marathilipi",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.ternary.marathilipi",
          "match": "(\\?|:)"
        },
        {
          "name": "keyword.operator.spread.marathilipi",
          "match": "(\\.\\.\\.)"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.marathilipi",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.array.marathilipi",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.parameters.marathilipi",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.comma.marathilipi",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.marathilipi",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.marathilipi",
          "match": "\\."
        }
      ]
    }

  }
}
