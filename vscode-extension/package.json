{
  "name": "marathilipi-language",
  "displayName": "MarathiLipi Language Support",
  "description": "Syntax highlighting, snippets, autocomplete, hover info, and diagnostics for MarathiLipi — write TypeScript using Marathi (Devanagari) keywords.",
  "version": "0.1.0",
  "publisher": "marathilipi",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "marathi",
    "devanagari",
    "marathilipi",
    "syntax highlighting",
    "programming language"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuyutsu/marathilipi"
  },
  "bugs": {
    "url": "https://github.com/Yuyutsu/marathilipi/issues"
  },
  "activationEvents": [
    "onLanguage:marathilipi"
  ],
  "main": "./out/extension",
  "contributes": {
    "languages": [
      {
        "id": "marathilipi",
        "aliases": [
          "MarathiLipi",
          "marathi"
        ],
        "extensions": [
          ".ml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "marathilipi",
        "scopeName": "source.marathilipi",
        "path": "./syntaxes/marathilipi.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "marathilipi",
        "path": "./snippets/marathilipi.code-snippets.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json",
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.5"
  }
}
